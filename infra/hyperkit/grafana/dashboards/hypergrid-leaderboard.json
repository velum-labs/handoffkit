          "legendFormat": "Completed",
          "range": false,
          "instant": true,
          "refId": "C",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "hyperkit_cell_planned_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\", generation=~\"$generation\"}",
