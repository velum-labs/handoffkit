          "legendFormat": "Resolved",
          "range": false,
          "instant": true,
          "refId": "A",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "hyperkit_cell_completed_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\", generation=~\"$generation\"} + clamp_min(hyperkit_cell_planned_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\", generation=~\"$generation\"} - hyperkit_cell_completed_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\", generation=~\"$generation\"}, 0)",
