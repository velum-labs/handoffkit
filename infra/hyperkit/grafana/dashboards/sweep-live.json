      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(hyperkit_shards_running{run_id=~\"$run_id\"}) or vector(0)",
          "legendFormat": "running",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Running shards",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "amp"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(hyperkit_shards_failed_total{run_id=~\"$run_id\"}[$__range])) or vector(0)",
          "legendFormat": "failed",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Failures in range",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "amp"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, stage) (rate(hyperkit_stage_duration_seconds_bucket{run_id=~\"$run_id\"}[5m])))",
          "legendFormat": "p50 {{stage}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(hyperkit_stage_duration_seconds_bucket{run_id=~\"$run_id\"}[5m])))",
          "legendFormat": "p95 {{stage}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Stage latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-athena-datasource",
        "uid": "athena"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "format": 1,
          "rawSQL": "SELECT status, count(*) AS shards, avg(latency_s) AS avg_latency_s, sum(cost_usd) AS cost_usd FROM shard_results WHERE sweep_id = '$run_id' GROUP BY status ORDER BY status",
          "refId": "A"
        }
      ],
      "title": "Durable shard results",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 40,
  "tags": [
    "hyperkit",
    "sweep"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "label": "Run ID",
        "name": "run_id",
        "options": [],
        "query": ".*",
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
