{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "amp"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "width": 110
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cell"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Topology hash"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 14,
        "w": 14,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "hyperkit_cells_total{run_id=~\"$run_id\", benchmark=~\"$benchmark\"}",
          "legendFormat": "Cells",
          "range": false,
          "instant": true,
          "refId": "A",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "sum by (run_id, benchmark, generation) (hyperkit_cell_planned_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "Planned",
          "range": false,
          "instant": true,
          "refId": "B",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "sum by (run_id, benchmark, generation) (hyperkit_cell_completed_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "Completed",
          "range": false,
          "instant": true,
          "refId": "C",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "sum by (run_id, benchmark, generation) (hyperkit_cell_resolved_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "Resolved",
          "range": false,
          "instant": true,
          "refId": "D",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "hyperkit_shards_running{run_id=~\"$run_id\", benchmark=~\"$benchmark\"}",
          "legendFormat": "Running",
          "range": false,
          "instant": true,
          "refId": "E",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "hyperkit_shards_pending{run_id=~\"$run_id\", benchmark=~\"$benchmark\"}",
          "legendFormat": "Pending",
          "range": false,
          "instant": true,
          "refId": "F",
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "sum by (run_id, benchmark, generation) (hyperkit_cell_errors{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "Errors",
          "range": false,
          "instant": true,
          "refId": "G",
          "format": "table"
        }
      ],
      "title": "Search coverage by generation",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "generation",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "Value #A": "Cells",
              "Value #B": "Planned",
              "Value #C": "Completed",
              "Value #D": "Resolved",
              "Value #E": "Running",
              "Value #F": "Pending",
              "Value #G": "Errors",
              "benchmark 1": "Benchmark",
              "cell_id": "Cell",
              "commit 1": "Commit",
              "generation": "Generation",
              "generation 1": "Generation",
              "judge 1": "Judge",
              "k 1": "K",
              "panel 1": "Panel",
              "run_id 1": "Run",
              "topology 1": "Topology",
              "topology_hash 1": "Topology hash"
            },
            "indexByName": {
              "generation": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6,
              "Value #G": 7,
              "benchmark 1": 8,
              "run_id 1": 9
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "amp"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 0
      },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (generation) (hyperkit_cell_completed_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\"}) / sum by (generation) (hyperkit_cell_planned_shards{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "generation {{generation}}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Generation progress",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "amp"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 7
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "avg by (generation) (hyperkit_cell_resolution_rate{run_id=~\"$run_id\", benchmark=~\"$benchmark\"})",
          "legendFormat": "generation {{generation}}",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "title": "Generation resolution rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 40,
  "tags": [
    "hyperkit",
    "hypergrid",
    "generation",
    "coverage"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "amp"
        },
        "definition": "label_values(hyperkit_cell_resolution_rate, run_id)",
        "includeAll": true,
        "label": "Run Id",
        "multi": false,
        "name": "run_id",
        "query": {
          "query": "label_values(hyperkit_cell_resolution_rate, run_id)",
          "refId": "var-run_id"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "amp"
        },
        "definition": "label_values(hyperkit_cell_resolution_rate{run_id=~\"$run_id\"}, benchmark)",
        "includeAll": true,
        "label": "Benchmark",
        "multi": false,
        "name": "benchmark",
        "query": {
          "query": "label_values(hyperkit_cell_resolution_rate{run_id=~\"$run_id\"}, benchmark)",
          "refId": "var-benchmark"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Hypergrid Generation Coverage",
  "uid": "hyperkit-generation-coverage",
  "version": 1
}
