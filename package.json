{
  "name": "warrant",
  "private": true,
  "version": "0.8.0",
  "description": "The governed execution and provenance plane for AI agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.4"
  },
  "scripts": {
    "check": "node scripts/check-repo.mjs",
    "build": "tsc -b tsconfig.json",
    "build:cli": "tsc -b packages/cli",
    "clean": "tsc -b tsconfig.json --clean",
    "test": "PORTLESS=0 node --test \"packages/*/dist/test/*.test.js\" \"legacy/packages/*/dist/test/*.test.js\" \"examples/*/dist/test/*.test.js\" \"legacy/examples/*/dist/test/*.test.js\" \"test/*.test.js\"",
    "demo": "node scripts/demo.mjs",
    "dev:link-cli": "node scripts/link-fusionkit-dev.mjs",
    "dev:run-cli": "node scripts/fusionkit-dev.mjs",
    "docs:generate-code": "node scripts/generate-code-docs.mjs",
    "docs:check-code": "node scripts/generate-code-docs.mjs --check",
    "mlx": "node examples/mlx/dist/run.js",
    "mlx:stress": "node examples/mlx/dist/stress.js",
    "bench": "node examples/bench/dist/run.js",
    "microvm:bench": "node legacy/examples/microvm-isolation-bench/dist/run.js",
    "verify": "pnpm check && pnpm build && pnpm test",
    "release:plan": "node scripts/release.mjs plan",
    "release:apply": "node scripts/release.mjs apply",
    "release:graph": "node scripts/release.mjs graph",
    "release:refresh": "node scripts/release.mjs refresh",
    "mono": "node scripts/monorepo.mjs"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "@velum-labs/model-fusion-protocol": "0.5.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8"
    }
  }
}
