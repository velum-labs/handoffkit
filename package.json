{
  "name": "warrant",
  "private": true,
  "version": "0.1.0",
  "description": "The governed execution and provenance plane for AI agents.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.4"
  },
  "scripts": {
    "check": "node scripts/check-repo.mjs",
    "build": "tsc -b tsconfig.json",
    "clean": "tsc -b tsconfig.json --clean",
    "test": "node --test \"packages/*/dist/test/*.test.js\" \"examples/*/dist/test/*.test.js\" \"test/*.test.js\"",
    "demo": "node scripts/demo.mjs",
    "mlx": "node examples/mlx/dist/run.js",
    "mlx:stress": "node examples/mlx/dist/stress.js",
    "bench": "node examples/bench/dist/run.js",
    "microvm:bench": "node examples/microvm-isolation-bench/dist/run.js",
    "verify": "pnpm check && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "typescript": "5.9.3"
  }
}
