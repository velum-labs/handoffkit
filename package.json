{
  "name": "fusionkit-monorepo",
  "private": true,
  "version": "0.8.0",
  "description": "FusionKit: model fusion behind your coding agent.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.4"
  },
  "scripts": {
    "check": "node scripts/check-repo.mjs",
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=@fusionkit/cli...",
    "build:routekit": "turbo run build --filter=@routekit/cli...",
    "clean": "turbo run clean",
    "test": "PORTLESS=0 turbo run test && pnpm run test:root",
    "test:root": "PORTLESS=0 node --test \"test/*.test.js\"",
    "test:routekit-pack": "node scripts/check-routekit-cli-pack.mjs",
    "test:fusionkit-pack": "node scripts/check-fusionkit-cli-pack.mjs",
    "test:dual-cli-pack": "node scripts/check-dual-cli-pack.mjs",
    "test:e2e:matrix": "turbo run build --filter=@routekit/cli... --filter=@fusionkit/testkit... && node scripts/routekit-e2e-matrix.mjs",
    "demo": "node scripts/demo.mjs",
    "dev:link-cli": "node scripts/link-fusionkit-dev.mjs",
    "dev:run-cli": "node scripts/fusionkit-dev.mjs",
    "dev:link-routekit": "node scripts/link-routekit-dev.mjs",
    "dev:run-routekit": "node scripts/routekit-dev.mjs",
    "docs:generate-code": "node scripts/generate-code-docs.mjs",
    "docs:check-code": "node scripts/generate-code-docs.mjs --check",
    "docs:generate-behaviors": "node scripts/generate-expected-behaviors.mjs",
    "docs:check-behaviors": "node scripts/generate-expected-behaviors.mjs --check",
    "docs:generate-routekit-evidence": "node scripts/generate-routekit-l06-evidence.mjs",
    "docs:check-routekit-evidence": "node scripts/generate-routekit-l06-evidence.mjs --check",
    "mlx": "node examples/mlx/dist/run.js",
    "mlx:stress": "node examples/mlx/dist/stress.js",
    "verify": "pnpm check && pnpm build && pnpm test",
    "release:plan": "node scripts/release.mjs plan",
    "release:apply": "node scripts/release.mjs apply",
    "release:graph": "node scripts/release.mjs graph",
    "release:refresh": "node scripts/release.mjs refresh",
    "mono": "node scripts/monorepo.mjs"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "@velum-labs/model-fusion-protocol": "file:spec/model-fusion-contract",
    "turbo": "2.10.5",
    "typescript": "6.0.3"
  }
}
