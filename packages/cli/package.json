{
  "name": "@fusionkit/cli",
  "private": false,
  "version": "0.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/cli"
  },
  "description": "fusionkit — real model fusion behind your coding agent (Codex, Claude Code, Cursor, OpenCode).",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "fusionkit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scope",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fusionkit/adapter-ai-sdk": "workspace:*",
    "@fusionkit/config": "workspace:*",
    "@velum-labs/routekit-cli-core": "workspace:*",
    "@velum-labs/routekit-cli-ui": "workspace:*",
    "@velum-labs/routekit-config-core": "workspace:*",
    "@velum-labs/routekit-config": "workspace:*",
    "@velum-labs/routekit-telemetry-core": "workspace:*",
    "@fusionkit/ensemble": "workspace:*",
    "@velum-labs/routekit-harness-core": "workspace:*",
    "@fusionkit/gateway": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/registry": "workspace:*",
    "@velum-labs/routekit-runtime": "workspace:*",
    "@velum-labs/routekit-tool-registry": "workspace:*",
    "@velum-labs/routekit-tools": "workspace:*",
    "@fusionkit/tracing": "workspace:*",
    "@fusionkit/workspace": "workspace:*",
    "@velum-labs/routekit-contracts": "workspace:*",
    "@velum-labs/routekit-gateway": "workspace:*",
    "@velum-labs/routekit-registry": "workspace:*",
    "@velum-labs/routekit-router": "workspace:*",
    "commander": "14.0.3",
    "figlet": "1.11.0",
    "posthog-node": "5.46.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@fusionkit/testkit": "workspace:*",
    "@types/figlet": "1.7.0"
  },
  "keywords": [
    "fusionkit",
    "model-fusion",
    "llm",
    "ensemble",
    "coding-agent",
    "cli",
    "codex",
    "claude-code",
    "cursor",
    "opencode"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
