{
  "name": "@fusionkit/cli",
  "private": false,
  "version": "0.5.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/cli"
  },
  "description": "fusionkit — real model fusion behind your coding agent (codex, claude, cursor).",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "fusionkit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "default": "./dist/render.js"
    }
  },
  "files": [
    "dist",
    "scope"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fusionkit/ensemble": "workspace:*",
    "@fusionkit/handoff": "workspace:*",
    "@fusionkit/model-gateway": "workspace:*",
    "@fusionkit/plane": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/runner": "workspace:*",
    "@fusionkit/sdk": "workspace:*",
    "@fusionkit/tool-claude": "workspace:*",
    "@fusionkit/tool-codex": "workspace:*",
    "@fusionkit/tool-cursor": "workspace:*",
    "@fusionkit/tool-opencode": "workspace:*",
    "@fusionkit/tools": "workspace:*",
    "@fusionkit/workspace": "workspace:*",
    "commander": "14.0.3"
  },
  "optionalDependencies": {
    "portless": "0.14.0"
  },
  "devDependencies": {
    "@fusionkit/testkit": "workspace:*"
  }
}
