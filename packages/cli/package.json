{
  "name": "@fusionkit/cli",
  "private": false,
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/cli"
  },
  "description": "fusionkit — real model fusion behind your coding agent (codex, claude, cursor).",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "fusionkit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scope",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fusionkit/adapter-ai-sdk": "workspace:*",
    "@fusionkit/cli-ui": "workspace:*",
    "@fusionkit/ensemble": "workspace:*",
    "@fusionkit/harness-core": "workspace:*",
    "@fusionkit/model-gateway": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/registry": "workspace:*",
    "@fusionkit/runtime-utils": "workspace:*",
    "@fusionkit/tool-claude": "workspace:*",
    "@fusionkit/tool-codex": "workspace:*",
    "@fusionkit/tool-cursor": "workspace:*",
    "@fusionkit/tool-opencode": "workspace:*",
    "@fusionkit/tools": "workspace:*",
    "@fusionkit/tracing": "workspace:*",
    "@fusionkit/workspace": "workspace:*",
    "@routekit/contracts": "workspace:*",
    "@routekit/registry": "workspace:*",
    "commander": "14.0.3",
    "figlet": "1.11.0",
    "openai": "6.46.0",
    "posthog-node": "5.39.4",
    "untun": "0.1.3",
    "yaml": "2.9.0"
  },
  "optionalDependencies": {
    "portless": "0.15.1"
  },
  "devDependencies": {
    "@fusionkit/testkit": "workspace:*",
    "@types/figlet": "1.7.0"
  },
  "keywords": [
    "fusionkit",
    "model-fusion",
    "llm",
    "ensemble",
    "coding-agent",
    "cli",
    "codex",
    "claude-code",
    "cursor"
  ],
  "scripts": {
    "test": "node --test \"dist/test/*.test.js\""
  }
}
