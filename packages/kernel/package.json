{
  "name": "@fusionkit/kernel",
  "private": false,
  "version": "0.9.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/kernel"
  },
  "description": "FusionKit runtime kernel substrate: typed artifacts, operators, graphs, schedulers, budgets, traces, outcomes, streaming, and wire artifacts. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./graph-utils": {
      "types": "./dist/graph-utils.d.ts",
      "default": "./dist/graph-utils.js"
    },
    "./graph-validation": {
      "types": "./dist/graph-validation.d.ts",
      "default": "./dist/graph-validation.js"
    },
    "./artifact-types": {
      "types": "./dist/artifact-types.d.ts",
      "default": "./dist/artifact-types.js"
    },
    "./wire-artifacts": {
      "types": "./dist/wire-artifacts.d.ts",
      "default": "./dist/wire-artifacts.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "fusionkit",
    "model-fusion",
    "llm",
    "ensemble",
    "coding-agent",
    "runtime-kernel",
    "operators",
    "schedulers"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
