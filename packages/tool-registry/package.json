{
  "name": "@velum-labs/routekit-tool-registry",
  "private": false,
  "version": "0.9.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/tool-registry"
  },
  "description": "Canonical product-neutral registry of RouteKit coding-tool integrations.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@velum-labs/routekit-tool-claude": "workspace:*",
    "@velum-labs/routekit-tool-codex": "workspace:*",
    "@velum-labs/routekit-tool-cursor": "workspace:*",
    "@velum-labs/routekit-tool-opencode": "workspace:*",
    "@velum-labs/routekit-tools": "workspace:*"
  },
  "keywords": [
    "routekit",
    "llm",
    "coding-agent",
    "tooling",
    "registry"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
