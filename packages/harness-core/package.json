{
  "name": "@velum-labs/routekit-harness-core",
  "private": false,
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/harness-core"
  },
  "description": "Product-neutral coding-agent driver, instance, session, event, error, approval, and status contracts.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "dependencies": {
    "@velum-labs/routekit-runtime": "workspace:*",
    "@velum-labs/routekit-contracts": "workspace:*",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "llm",
    "coding-agent",
    "harness",
    "driver",
    "testing"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
