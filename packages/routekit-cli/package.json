{
  "name": "@velum-labs/routekit",
  "private": false,
  "version": "0.9.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/routekit-cli"
  },
  "description": "RouteKit CLI for configuring, serving, and using model gateways.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "routekit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@velum-labs/routekit-accounts": "workspace:*",
    "@velum-labs/routekit-cli-core": "workspace:*",
    "@velum-labs/routekit-cli-ui": "workspace:*",
    "@velum-labs/routekit-config": "workspace:*",
    "@velum-labs/routekit-control": "workspace:*",
    "@velum-labs/routekit-contracts": "workspace:*",
    "@velum-labs/routekit-daemon": "workspace:*",
    "@velum-labs/routekit-gateway": "workspace:*",
    "@velum-labs/routekit-registry": "workspace:*",
    "@velum-labs/routekit-router": "workspace:*",
    "@velum-labs/routekit-runtime": "workspace:*",
    "@velum-labs/routekit-telemetry-core": "workspace:*",
    "@velum-labs/routekit-tool-registry": "workspace:*",
    "@velum-labs/routekit-tools": "workspace:*",
    "commander": "14.0.3",
    "yaml": "2.9.0"
  },
  "keywords": [
    "routekit",
    "llm",
    "gateway",
    "router",
    "coding-agent",
    "cli"
  ],
  "scripts": {
    "build": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const path of ['dist', 'tsconfig.tsbuildinfo']) rmSync(path, { recursive: true, force: true })\" && tsc -b",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const path of ['dist', 'tsconfig.tsbuildinfo']) rmSync(path, { recursive: true, force: true })\"",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
