{
  "name": "@velum-labs/routekit-tools",
  "private": false,
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/tools"
  },
  "description": "Product-neutral coding tool launcher, driver, and capability registry.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@velum-labs/routekit-contracts": "workspace:*",
    "@velum-labs/routekit-harness-core": "workspace:*"
  },
  "keywords": [
    "llm",
    "coding-agent",
    "tooling",
    "harness",
    "adapter"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
