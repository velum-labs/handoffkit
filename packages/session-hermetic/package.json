{
  "name": "@warrant/session-hermetic",
  "private": false,
  "version": "0.1.0",
  "description": "Hermetic session backend for Warrant runners: a simulated bash interpreter (just-bash) with a virtual filesystem and interpreter-enforced network allowlists. No real processes or sockets to escape with.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "provenance": true
  },
  "dependencies": {
    "@warrant/protocol": "workspace:*",
    "@warrant/runner": "workspace:*",
    "just-bash": "3.0.1"
  },
  "devDependencies": {
    "@warrant/plane": "workspace:*",
    "@warrant/sdk": "workspace:*",
    "@warrant/testkit": "workspace:*",
    "@warrant/workspace": "workspace:*"
  }
}
