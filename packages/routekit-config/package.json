    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/routekit-config"
  },
  "description": "RouteKit router configuration discovery, loading, validation, and atomic writes.",
  "license": "Apache-2.0",
  "type": "module",
