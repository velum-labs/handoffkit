{
  "name": "@fusionkit/model-gateway",
  "private": false,
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/model-gateway"
  },
  "description": "FusionKit harness gateway: wire dialect translation, streaming, durable sessions, cost metering, rate-limit handoff, and model-fusion backend routing.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./subscriptions": {
      "types": "./dist/subscriptions/index.d.ts",
      "default": "./dist/subscriptions/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fusionkit/adapter-ai-sdk": "workspace:*",
    "@fusionkit/kernel": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/registry": "workspace:*",
    "@fusionkit/runtime-utils": "workspace:*",
    "@fusionkit/tracing": "workspace:*",
    "zod": "4.4.3"
  },
  "keywords": [
    "fusionkit",
    "model-fusion",
    "llm",
    "ensemble",
    "coding-agent",
    "gateway",
    "openai-compatible",
    "streaming"
  ],
  "scripts": {
    "test": "node --test \"dist/test/*.test.js\""
  }
}
