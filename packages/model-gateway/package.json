{
  "name": "@routekit/gateway",
  "private": false,
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/model-gateway"
  },
  "description": "Product-neutral model router, provider egress, wire dialect translation, streaming, catalog, and call provenance.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
