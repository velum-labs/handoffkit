{
  "openapi": "3.1.0",
  "info": {
    "title": "Model Fusion Harness Executor API",
    "version": "0.1.0",
    "description": "Consumer compatibility snapshot for the HandoffKit HTTP/JSON harness executor seam. FusionKit remains the canonical contract origin for v1."
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "x-canonical-source-repo": "fusionkit",
  "x-local-role": "consumer-compatibility-snapshot",
  "x-record-format": "json-schema",
  "paths": {
    "/v1/harness-executions": {
      "post": {
        "operationId": "executeHarnessTask",
        "summary": "Execute a model-fusion harness task",
        "description": "FusionKit calls this HTTP/JSON seam to ask a harness executor to run a coding task and return persisted JSON Schema audit records.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HarnessExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Harness execution completed or reached a terminal skipped/failed status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HarnessExecutionResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request shape or unsupported harness contract.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Executor is unavailable or missing explicitly requested live credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PersistedJsonRecord": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema", "schema_version", "schema_bundle_hash", "persisted_json"],
        "properties": {
          "schema": {
            "type": "string",
            "examples": ["harness-run-request.v1", "harness-run-result.v1"]
          },
          "schema_version": {
            "type": "string",
            "const": "v1"
          },
          "schema_bundle_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "persisted_json": {
            "type": "object",
            "description": "The durable JSON Schema audit/benchmark record. Consumers validate it with the generated model-fusion JSON Schema validators.",
            "additionalProperties": true
          }
        }
      },
      "ArtifactRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "kind", "hash"],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "redaction_status": {
            "type": "string",
            "enum": ["synthetic", "redacted", "raw"]
          }
        }
      },
      "HarnessExecutionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "request_id",
          "task_id",
          "source_repo",
          "base_git_sha",
          "harness_kind",
          "prompt_hash",
          "allowed_tools",
          "side_effects",
          "harness_run_request"
        ],
        "properties": {
          "request_id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "source_repo": {
            "type": "string"
          },
          "base_git_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "harness_kind": {
            "type": "string"
          },
          "prompt_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "side_effects": {
            "type": "string"
          },
          "harness_run_request": {
            "$ref": "#/components/schemas/PersistedJsonRecord"
          }
        }
      },
      "HarnessExecutionResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "request_id",
          "result_id",
          "status",
          "candidate_ids",
          "harness_run_result"
        ],
        "properties": {
          "request_id": {
            "type": "string"
          },
          "result_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "candidate_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtifactRef"
            }
          },
          "harness_run_result": {
            "$ref": "#/components/schemas/PersistedJsonRecord"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    }
  }
}
