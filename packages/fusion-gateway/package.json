{
  "name": "@fusionkit/gateway",
  "private": false,
  "version": "0.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/fusion-gateway"
  },
  "description": "FusionKit panel orchestration, synthesis gateway, session persistence, and aggregate cost accounting.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fusionkit/adapter-ai-sdk": "workspace:*",
    "@fusionkit/kernel": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/registry": "workspace:*",
    "@fusionkit/tracing": "workspace:*",
    "@velum-labs/routekit-contracts": "workspace:*",
    "@velum-labs/routekit-gateway": "workspace:*",
    "@velum-labs/routekit-registry": "workspace:*",
    "@velum-labs/routekit-runtime": "workspace:*",
    "@velum-labs/routekit-tracing": "workspace:*"
  },
  "keywords": [
    "fusionkit",
    "model-fusion",
    "ensemble",
    "gateway"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/test/*.test.js\""
  }
}
