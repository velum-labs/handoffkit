{
  "name": "@fusionkit/adapter-ai-sdk",
  "private": false,
  "version": "0.5.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velum-labs/handoffkit.git",
    "directory": "packages/adapter-ai-sdk"
  },
  "description": "AI SDK adapter for app-owned loops: tool calls execute in governed runner sessions and return with receipts. No durability claim attaches to the caller's loop.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.48",
    "@ai-sdk/provider": "3.0.10",
    "@fusionkit/handoff": "workspace:*",
    "@fusionkit/protocol": "workspace:*",
    "@fusionkit/sdk": "workspace:*",
    "ai": "6.0.200",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@fusionkit/testkit": "workspace:*"
  }
}
