{
  "name": "scope",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Local observability companion for the fusion stack (FusionKit + HandoffKit + Cursorkit). Visualizes sessions, environments, panel-model trajectories, and the judge's thinking-to-final flow over a live fusion-trace event spine.",
  "scripts": {
    "dev": "portless",
    "dev:app": "next dev -p 4317",
    "build": "next build",
    "start": "next start -p 4317",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "portless": { "name": "scope", "script": "dev:app" },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.20.0",
    "next": "15.5.21",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "2.15.4",
    "shadcn": "4.11.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "22.19.20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
