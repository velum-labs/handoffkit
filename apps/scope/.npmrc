# Local, relaxed config for the isolated dashboard app. Kept separate from the
# monorepo root .npmrc on purpose so the strict exact-version pinning, peer
# strictness, and release-age gates don't apply to this self-contained app.
auto-install-peers=true
strict-peer-dependencies=false
save-exact=false

# Flat (npm-style) node_modules instead of pnpm's symlinked virtual store. The
# `next build` standalone output is staged into and shipped inside the
# @fusionkit/cli npm tarball; a hoisted layout copies real files (no .pnpm
# symlink farm), which packs/unpacks portably across npm clients and OSes.
node-linker=hoisted
