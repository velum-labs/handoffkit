{
  "openapi": "3.1.0",
  "info": {
    "title": "Model Fusion Protocol HTTP API",
    "version": "0.2.0",
    "description": "V1 HTTP/JSON service surfaces for model-fusion integrations. Durable records are JSON Schema payloads from ../schema.",
    "x-schema-bundle-hash": "sha256:aae33b89a771fd5916e21bfffc5993d2d7ef98ecfc8542ba9570a8c99074d541"
  },
  "paths": {
    "/v1/harness/execute-coding-task": {
      "post": {
        "operationId": "executeCodingTask",
        "tags": ["HarnessExecutorService"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteCodingTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Handoff-compatible harness execution result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteCodingTaskResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/cursor/normalize-run": {
      "post": {
        "operationId": "normalizeCursorRun",
        "tags": ["CursorHarnessService"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NormalizeCursorRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cursor adapter output normalized to harness records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NormalizeCursorRunResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mlx/model-endpoints/{endpoint_id}": {
      "get": {
        "operationId": "describeModelEndpoint",
        "tags": ["MlxProviderService"],
        "parameters": [
          {
            "name": "endpoint_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Provider capability metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DescribeModelEndpointResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mlx/model-calls": {
      "post": {
        "operationId": "recordModelCallMetadata",
        "tags": ["MlxProviderService"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordModelCallMetadataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validated model-call metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordModelCallMetadataResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/benchmarks/join-execution": {
      "post": {
        "operationId": "joinExecutionRecords",
        "tags": ["BenchmarkJoinService"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinExecutionRecordsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Joined benchmark execution records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JoinExecutionRecordsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContractRecord": {
        "oneOf": [
          { "$ref": "../schema/artifact-ref.v1.schema.json" },
          { "$ref": "../schema/benchmark-task-record.v1.schema.json" },
          { "$ref": "../schema/cursor-run-result.v1.schema.json" },
          { "$ref": "../schema/ensemble-receipt.v1.schema.json" },
          { "$ref": "../schema/fusion-record.v1.schema.json" },
          { "$ref": "../schema/harness-candidate-record.v1.schema.json" },
          { "$ref": "../schema/harness-run-result.v1.schema.json" },
          { "$ref": "../schema/judge-synthesis-record.v1.schema.json" },
          { "$ref": "../schema/model-call-record.v1.schema.json" },
          { "$ref": "../schema/model-endpoint.v1.schema.json" },
          { "$ref": "../schema/tool-call-plan.v1.schema.json" },
          { "$ref": "../schema/tool-execution-record.v1.schema.json" }
        ]
      },
      "ExecuteCodingTaskRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["benchmark_task_record"],
        "properties": {
          "benchmark_task_record": {
            "$ref": "../schema/benchmark-task-record.v1.schema.json"
          },
          "manifest_path": {
            "type": "string"
          },
          "manifest_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "requested_model_endpoints": {
            "type": "array",
            "items": {
              "$ref": "../schema/model-endpoint.v1.schema.json"
            }
          }
        }
      },
      "ExecuteCodingTaskResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["harness_run_result", "records"],
        "properties": {
          "harness_run_result": {
            "$ref": "../schema/harness-run-result.v1.schema.json"
          },
          "harness_candidate_records": {
            "type": "array",
            "items": {
              "$ref": "../schema/harness-candidate-record.v1.schema.json"
            }
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractRecord"
            }
          }
        }
      },
      "NormalizeCursorRunRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cursor_run_result"],
        "properties": {
          "cursor_run_result": {
            "$ref": "../schema/cursor-run-result.v1.schema.json"
          }
        }
      },
      "NormalizeCursorRunResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["harness_run_result", "records"],
        "properties": {
          "harness_run_result": {
            "$ref": "../schema/harness-run-result.v1.schema.json"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractRecord"
            }
          }
        }
      },
      "DescribeModelEndpointResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_endpoint"],
        "properties": {
          "model_endpoint": {
            "$ref": "../schema/model-endpoint.v1.schema.json"
          }
        }
      },
      "RecordModelCallMetadataRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_call_record"],
        "properties": {
          "model_call_record": {
            "$ref": "../schema/model-call-record.v1.schema.json"
          }
        }
      },
      "RecordModelCallMetadataResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_call_record"],
        "properties": {
          "model_call_record": {
            "$ref": "../schema/model-call-record.v1.schema.json"
          }
        }
      },
      "JoinExecutionRecordsRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["benchmark_task_record", "execution_records"],
        "properties": {
          "benchmark_task_record": {
            "$ref": "../schema/benchmark-task-record.v1.schema.json"
          },
          "execution_records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractRecord"
            }
          }
        }
      },
      "JoinExecutionRecordsResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["joined_records"],
        "properties": {
          "joined_records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractRecord"
            }
          }
        }
      }
    }
  }
}
