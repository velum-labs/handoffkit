{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velum.ai/fusionkit/model-fusion-contract/cursor-run-result.v1.schema.json",
  "title": "cursor-run-result.v1",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/contractMetadata"
    },
    {
      "type": "object",
      "required": [
        "cursor_run_id",
        "harness_request_id",
        "status",
        "output_summary",
        "capabilities",
        "raw_hash",
        "redacted_hash"
      ],
      "properties": {
        "schema": {
          "const": "cursor-run-result.v1"
        },
        "cursor_run_id": {
          "type": "string",
          "minLength": 1
        },
        "harness_request_id": {
          "type": "string",
          "minLength": 1
        },
        "mapped_harness_result_id": {
          "type": "string"
        },
        "status": {
          "$ref": "common.schema.json#/$defs/status"
        },
        "output_summary": {
          "type": "string"
        },
        "transcript_artifact": {
          "$ref": "common.schema.json#/$defs/artifactRef"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/artifactRef"
          }
        },
        "capabilities": {
          "$ref": "common.schema.json#/$defs/capabilityMap"
        },
        "raw_hash": {
          "$ref": "common.schema.json#/$defs/hash"
        },
        "redacted_hash": {
          "$ref": "common.schema.json#/$defs/hash"
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
