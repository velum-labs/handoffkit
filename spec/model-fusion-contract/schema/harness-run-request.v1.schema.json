{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velum.ai/fusionkit/model-fusion-contract/harness-run-request.v1.schema.json",
  "title": "harness-run-request.v1",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/contractMetadata"
    },
    {
      "type": "object",
      "required": [
        "request_id",
        "harness_kind",
        "source_repo",
        "base_git_sha",
        "prompt",
        "prompt_hash",
        "side_effects",
        "requested_capabilities"
      ],
      "properties": {
        "schema": {
          "const": "harness-run-request.v1"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "harness_kind": {
          "$ref": "common.schema.json#/$defs/harness_kind"
        },
        "source_repo": {
          "type": "string",
          "minLength": 1
        },
        "base_git_sha": {
          "$ref": "common.schema.json#/$defs/gitSha"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "prompt_hash": {
          "$ref": "common.schema.json#/$defs/hash"
        },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "side_effects": {
          "$ref": "common.schema.json#/$defs/side_effects"
        },
        "requested_capabilities": {
          "$ref": "common.schema.json#/$defs/capabilityMap"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
