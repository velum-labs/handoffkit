{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velum.ai/fusionkit/model-fusion-contract/fusion-run-request.v1.schema.json",
  "title": "fusion-run-request.v1",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/contractMetadata"
    },
    {
      "type": "object",
      "required": [
        "request_id",
        "mode",
        "messages",
        "sampling",
        "verify"
      ],
      "properties": {
        "schema": {
          "const": "fusion-run-request.v1"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "single",
            "self",
            "panel",
            "router"
          ]
        },
        "messages": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/chatMessage"
          },
          "minItems": 1
        },
        "requested_models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sampling": {
          "$ref": "common.schema.json#/$defs/sampling"
        },
        "verify": {
          "type": "boolean"
        },
        "tool_policy": {
          "type": "string",
          "enum": [
            "disabled",
            "external_pause",
            "allowed"
          ]
        },
        "request_hash": {
          "$ref": "common.schema.json#/$defs/hash"
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
