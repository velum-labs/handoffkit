{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velum.ai/fusionkit/model-fusion-contract/tool-call-plan.v1.schema.json",
  "title": "tool-call-plan.v1",
  "description": "Minimal demo stub. Tool planning semantics land in later tickets.",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/contractMetadata"
    },
    {
      "type": "object",
      "required": [
        "plan_id",
        "tool_name",
        "arguments_hash",
        "side_effects",
        "status"
      ],
      "properties": {
        "schema": {
          "const": "tool-call-plan.v1"
        },
        "plan_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "arguments_hash": {
          "$ref": "common.schema.json#/$defs/hash"
        },
        "side_effects": {
          "$ref": "common.schema.json#/$defs/side_effects"
        },
        "status": {
          "$ref": "common.schema.json#/$defs/status"
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
